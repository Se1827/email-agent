# Groq
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Email source: "mock" (built-in sample emails) or "imap" (real mailbox)
EMAIL_SOURCE=mock

# IMAP settings (only needed when EMAIL_SOURCE=imap)
# Same settings you would use in Thunderbird or any email client.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASS=your-app-password
IMAP_MAILBOX=INBOX
IMAP_USE_SSL=true
IMAP_FETCH_LIMIT=20

# App
LOG_LEVEL=INFO
API_PORT=8000
UI_PORT=8501
